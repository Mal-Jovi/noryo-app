generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Patient {
  id                 Int          @id @default(autoincrement())
  phn                String       @unique
  firstName          String
  lastName           String
  city               String
  province           String
  gender             Gender
  age                Int
  birthday           DateTime
  familyDoctorId     Int?
  primaryDoctorId    Int
  lastClinicVisit    DateTime?
  nextClinicVisit    DateTime?
  allergies          String
  primaryCondition   String
  secondaryCondition String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  familyDoctor       Doctor?      @relation("PatientFamilyDoctor", fields: [familyDoctorId], references: [id])
  primaryDoctor      Doctor       @relation("PatientPrimaryDoctor", fields: [primaryDoctorId], references: [id])
  medications        Medication[] @relation("PatientMedications")

  @@index([phn])
  @@index([lastClinicVisit])
  @@index([familyDoctorId], map: "Patient_familyDoctorId_fkey")
  @@index([primaryDoctorId], map: "Patient_primaryDoctorId_fkey")
}

model Doctor {
  id              Int       @id @default(autoincrement())
  firstName       String
  lastName        String
  licenseNum      String
  createdAt       DateTime  @default(now())
  familyPatients  Patient[] @relation("PatientFamilyDoctor")
  primaryPatients Patient[] @relation("PatientPrimaryDoctor")
}

model Medication {
  id                       Int      @id @default(autoincrement())
  drugIdentificationNumber Int
  genericName              String
  brandName                String
  type                     String
  drugClass                String
  controlledSubstance      Boolean
  patientId                Int?
  patient                  Patient? @relation("PatientMedications", fields: [patientId], references: [id])

  @@index([drugIdentificationNumber])
  @@index([genericName])
  @@index([brandName])
  @@index([patientId], map: "Medication_patientId_fkey")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  NOT_SPECIFIED
}
